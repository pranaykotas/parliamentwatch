# Streamlit Cloud secrets — copy this to .streamlit/secrets.toml locally,
# and paste each key into the Streamlit Cloud "Secrets" panel.

# LLM configuration
LLM_PROVIDER = "anthropic"
LLM_API_KEY = "your-anthropic-api-key-here"
# LLM_MODEL = "claude-sonnet-4-20250514"

# Email notifications (optional — leave blank to disable)
NOTIFICATION_EMAIL = ""
SENDER_EMAIL = ""
SMTP_SERVER = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USERNAME = ""
SMTP_PASSWORD = ""

# Lok Sabha number (default: 18)
# LOK_SABHA_NUMBER = "18"
